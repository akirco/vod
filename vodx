#!/usr/bin/env bash

# 检查必需的依赖工具
check_dependencies() {
    local missing_deps=()

    for cmd in jq fzf mpv base64 md5sum; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing_deps+=("$cmd")
        fi
    done

    if [ ${#missing_deps[@]} -ne 0 ]; then
        echo "错误: 缺少必需的依赖工具: ${missing_deps[*]}"
        echo "请安装缺失的工具后再运行。"
        exit 1
    fi
}

# 统一的fzf选择函数
select_with_fzf() {
    local list="$1"
    local prompt="$2"
    local height="${3:-100%}"
    local preview="${4:-}"

    echo "$list" | fzf --delimiter='\t' --with-nth 1 \
        --height="$height" --reverse --border --cycle \
        --prompt="$prompt > " \
        ${preview:+--preview="$preview"}
}

check_dependencies

# 参数解析
show_help() {
    echo "用法: $(basename $0) [选项] <搜索关键词>"
    echo "选项:"
    echo "  -h, --help     显示此帮助信息"
    echo "  -c, --clear    清除缓存"
    echo "  --no-cache     跳过缓存，直接搜索"
    echo "示例:"
    echo "  $(basename $0) 绝命毒师"
    echo "  $(basename $0) -c          # 清除缓存"
    echo "  $(basename $0) --no-cache 电影名"
}

CLEAR_CACHE=false
SKIP_CACHE=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            show_help
            exit 0
            ;;
        -c|--clear)
            CLEAR_CACHE=true
            shift
            ;;
        --no-cache)
            SKIP_CACHE=true
            shift
            ;;
        -*)
            echo "未知选项: $1"
            show_help
            exit 1
            ;;
        *)
            KEYWORD="$1"
            shift
            ;;
    esac
done

# 处理清除缓存选项
if [ "$CLEAR_CACHE" = true ]; then
    if [ -d "$CACHE_DIR" ]; then
        rm -rf "$CACHE_DIR"
        echo "缓存已清除。"
    else
        echo "缓存目录不存在。"
    fi
    exit 0
fi

if [ -z "$KEYWORD" ]; then
    show_help
    exit 1
fi

# === 缓存设置 ===
CACHE_DIR="$HOME/.cache/vod"
mkdir -p "$CACHE_DIR"

# 缓存过期时间（24小时）
CACHE_TTL=$((24 * 3600))

# 计算关键词的 MD5 值作为缓存文件名，防止特殊字符导致路径错误
KEYWORD_HASH=$(printf '%s' "$KEYWORD" | md5sum | cut -d' ' -f1)
CACHE_FILE="$CACHE_DIR/${KEYWORD_HASH}.json"

# 检查缓存是否有效
is_cache_valid() {
    local cache_file="$1"
    if [ ! -f "$cache_file" ]; then
        return 1
    fi

    local cache_age=$(( $(date +%s) - $(stat -c %Y "$cache_file" 2>/dev/null || stat -f %m "$cache_file" 2>/dev/null || echo 0) ))
    if [ "$cache_age" -gt "$CACHE_TTL" ]; then
        return 1
    fi

    return 0
}

if [ "$SKIP_CACHE" = false ] && is_cache_valid "$CACHE_FILE"; then
    echo "正在从缓存加载: $KEYWORD ..."
    JSON_DATA=$(cat "$CACHE_FILE")
else
    echo "正在搜索: $KEYWORD ..."
    JSON_DATA=$(vod -w "$KEYWORD" -a detail -j)

    if [ -z "$JSON_DATA" ]; then
        echo "错误: 未搜索到数据或 vod 命令执行失败。"
        echo "请检查网络连接或确认关键词正确。"
        exit 1
    fi

    if [ "$SKIP_CACHE" = false ]; then
        echo "$JSON_DATA" >"$CACHE_FILE"
        echo "已缓存搜索结果。"
    fi
fi

if [ -z "$JSON_DATA" ]; then
    echo "数据为空，请检查。"
    exit 1
fi

COUNT=$(echo "$JSON_DATA" | jq '. | length')
if [ "$COUNT" -eq 0 ]; then
    echo "未找到相关结果。"
    exit 1
fi

echo "找到 $COUNT 个结果"

USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

# 预处理视频列表，减少重复计算
VOD_LIST=$(echo "$JSON_DATA" | jq -r '.[] | "\(.vod_name) (\(.vod_year // "未知")) - \(.vod_remarks)\t\(@base64)"')

PREVIEW_CMD="
json_obj=\$(echo '{2}' | base64 -d)
pic_url=\$(echo \"\$json_obj\" | jq -r '.vod_pic')
name=\$(echo \"\$json_obj\" | jq -r '.vod_name')
blurb=\$(echo \"\$json_obj\" | jq -r '.vod_blurb')
director=\$(echo \"\$json_obj\" | jq -r '.vod_director')

echo -e \"\033[1;36m\$name\033[0m\"
echo \"------------------------------------------------\"
echo -e \"\033[1;33m导演:\033[0m \$director\"
echo \"\"
echo -e \"\$blurb\" | fold -s -w \$(( FZF_PREVIEW_COLUMNS * 60 / 100 ))
echo \"\"

if [ -n "\$pic_url" ] && [ "\$pic_url" != "null" ] && command -v chafa >/dev/null 2>&1; then
    # 使用缓存图片避免重复下载
    pic_cache_dir="$CACHE_DIR/pics"
    mkdir -p "\$pic_cache_dir"
    pic_filename=\$(printf '%s' "\$pic_url" | md5sum | cut -d' ' -f1)
    pic_cache_file="\$pic_cache_dir/\$pic_filename.jpg"

    if [ ! -f "\$pic_cache_file" ] || [ \$((\$(date +%s) - \$(stat -c %Y "\$pic_cache_file" 2>/dev/null || echo 0))) -gt 3600 ]; then
        curl -s -H 'User-Agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36' --max-time 5 "\$pic_url" -o "\$pic_cache_file" 2>/dev/null
    fi

    if [ -f "\$pic_cache_file" ] && [ -s "\$pic_cache_file" ]; then
        chafa -s "\${FZF_PREVIEW_COLUMNS:-40}x\${FZF_PREVIEW_LINES:-10}" "\$pic_cache_file" 2>/dev/null || echo "[图片加载失败]"
    else
        echo "[暂无海报]"
    fi
else
    echo "[暂无海报]"
fi
"

SELECTED_LINE=$(select_with_fzf "$VOD_LIST" "VOD" "100%" "$PREVIEW_CMD")

if [ -z "$SELECTED_LINE" ]; then
    echo "已取消选择。"
    exit 0
fi

SELECTED_B64=$(echo "$SELECTED_LINE" | cut -f2)
VOD_JSON=$(echo "$SELECTED_B64" | base64 -d)

VOD_NAME=$(echo "$VOD_JSON" | jq -r '.vod_name')
PLAY_URL_STR=$(echo "$VOD_JSON" | jq -r '.vod_play_url')

if [ -z "$PLAY_URL_STR" ] || [ "$PLAY_URL_STR" = "null" ]; then
    echo "该资源暂无播放链接。"
    exit 1
fi

EPISODE_LIST=$(echo "$PLAY_URL_STR" | tr '#' '\n' | awk -F'$' '{print $1 "\t" $2}')

SELECTED_EP=$(select_with_fzf "$EPISODE_LIST" "$VOD_NAME > 选择集数" "30%")

if [ -z "$SELECTED_EP" ]; then
    echo "已取消播放。"
    exit 0
fi

PLAY_URL=$(echo "$SELECTED_EP" | cut -f2)
echo "正在播放: $VOD_NAME - $(echo "$SELECTED_EP" | cut -f1)"

mpv --title="mpv - $VOD_NAME - $SELECTED_EP" "$PLAY_URL" --hwdec=auto
